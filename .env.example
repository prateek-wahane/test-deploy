# SMTP configuration for contact form emails (GoDaddy Workspace Email)
# Use smtpout.secureserver.net on port 465 (SSL) for outgoing mail
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@intelliwareglobal.com
SMTP_PASS=your-godaddy-email-password
SMTP_FROM=info@intelliwareglobal.com
